{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "strict": true,
        "esModuleInterop": true,
        "types": [
            "node",
            "vitest/globals"
        ],
        "skipLibCheck": true,
        "noEmit": true
    },
    "include": [
        "**/*.ts",
        "../src/**/*.ts"
    ]
}